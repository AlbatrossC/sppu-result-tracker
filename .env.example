# Copy this file to .env for local development.

# Neon PostgreSQL connection string.
# Get it from Neon Dashboard -> Project -> Connection Details.
# Use the pooled PostgreSQL URL and include the password.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require

# Discord webhook used by the GitHub Action to send result notifications.
# Get it from Discord -> Server Settings -> Integrations -> Webhooks.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Private secret shared by cron-job.org and the Vercel /api/trigger endpoint.
# You create this yourself. It can be any long random string.
WORKFLOW_SECRET=replace-with-a-long-random-secret

# GitHub token used by Vercel to dispatch the workflow.
# Create a fine-grained GitHub personal access token for this repo with Actions read/write access.


# Optional. Defaults already match this repo, so only set these if you rename/move things.
GH_REPO_NAME=AlbatrossC/sppu-result-tracker
GH_WORKFLOW_FILE=fetch.yml
GH_REF_BRANCH=main
